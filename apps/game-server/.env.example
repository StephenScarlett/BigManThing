# Supabase — cloud project (get from Supabase Dashboard → Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Service role key — NEVER expose to the browser. Get from Supabase Dashboard → Settings → API.
SUPABASE_SERVICE_ROLE_KEY=replace-me

# Game server
PORT=8787
ALLOWED_ORIGINS=http://localhost:5173
