# Supabase — cloud project (get from Supabase Dashboard → Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_replace-me

# Game server (Draw Nah — local dev)
VITE_GAME_SERVER_URL=http://localhost:8787

# Google Maps JS API key (Where Nah — Street View + Maps).
# Enable "Maps JavaScript API" and "Street View" in Google Cloud.
VITE_GOOGLE_MAPS_API_KEY=replace-me

# Google Maps Map ID (required for Advanced Markers).
VITE_GOOGLE_MAPS_MAP_ID=replace-me

# Optional theme-specific Map IDs. If set, the guess map will swap styles with
# the app theme. Leave blank to reuse VITE_GOOGLE_MAPS_MAP_ID for both.
VITE_GOOGLE_MAPS_MAP_ID_LIGHT=
VITE_GOOGLE_MAPS_MAP_ID_DARK=
